# Aim: Implement SJF (Non-Preemptive) CPU Scheduling

n = int(input("Enter number of processes: "))
bt = list(map(int, input("Enter burst times: ").split()))

processes = list(range(n))
combined = sorted(zip(bt, processes))

wt = [0]*n
tat = [0]*n

for i in range(1, n):
    wt[combined[i][1]] = wt[combined[i-1][1]] + combined[i-1][0]

for i in range(n):
    tat[i] = wt[i] + bt[i]

print("Process\tBT\tWT\tTAT")
for i in range(n):
    print(f"P{i+1}\t{bt[i]}\t{wt[i]}\t{tat[i]}")







# Aim: Implement SRT (Preemptive SJF)

n = int(input("Enter number of processes: "))
bt = list(map(int, input("Enter burst times: ").split()))

rt = bt[:]
wt = [0]*n
time = 0
complete = 0

while complete != n:
    min_bt = float('inf')
    shortest = -1
    
    for i in range(n):
        if rt[i] > 0 and rt[i] < min_bt:
            min_bt = rt[i]
            shortest = i

    rt[shortest] -= 1

    if rt[shortest] == 0:
        complete += 1
        finish = time + 1
        wt[shortest] = finish - bt[shortest]

    time += 1

tat = [bt[i] + wt[i] for i in range(n)]

print("Process\tBT\tWT\tTAT")
for i in range(n):
    print(f"P{i+1}\t{bt[i]}\t{wt[i]}\t{tat[i]}")






# Aim: Implement Round Robin Scheduling

n = int(input("Enter number of processes: "))
bt = list(map(int, input("Enter burst times: ").split()))
q = int(input("Enter time quantum: "))

rt = bt[:]
wt = [0]*n
t = 0

while True:
    done = True
    for i in range(n):
        if rt[i] > 0:
            done = False
            if rt[i] > q:
                t += q
                rt[i] -= q
            else:
                t += rt[i]
                wt[i] = t - bt[i]
                rt[i] = 0
    if done:
        break

tat = [bt[i] + wt[i] for i in range(n)]

print("Process\tBT\tWT\tTAT")
for i in range(n):
    print(f"P{i+1}\t{bt[i]}\t{wt[i]}\t{tat[i]}")







