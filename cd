# Aim: Implement Priority Scheduling (Preemptive)

n = int(input("Enter number of processes: "))

bt = list(map(int, input("Enter burst times: ").split()))
pr = list(map(int, input("Enter priorities (lower = higher priority): ").split()))

rt = bt[:]
wt = [0]*n
time = 0
complete = 0

while complete != n:
    highest = -1
    min_pr = float('inf')
    
    for i in range(n):
        if rt[i] > 0 and pr[i] < min_pr:
            min_pr = pr[i]
            highest = i

    rt[highest] -= 1

    if rt[highest] == 0:
        complete += 1
        finish = time + 1
        wt[highest] = finish - bt[highest]

    time += 1

tat = [wt[i] + bt[i] for i in range(n)]

print("Process\tBT\tPriority\tWT\tTAT")
for i in range(n):
    print(f"P{i+1}\t{bt[i]}\t{pr[i]}\t\t{wt[i]}\t{tat[i]}")








# Aim: Implement SJF Preemptive (Shortest Remaining Time First) Scheduling

n = int(input("Enter number of processes: "))

at = list(map(int, input("Enter arrival times: ").split()))
bt = list(map(int, input("Enter burst times: ").split()))

rt = bt[:]              # Remaining time
wt = [0]*n              # Waiting time
tat = [0]*n             # Turnaround time

time = 0
complete = 0
minm = float('inf')
shortest = 0
check = False

while complete != n:
    for i in range(n):
        if at[i] <= time and rt[i] > 0 and rt[i] < minm:
            minm = rt[i]
            shortest = i
            check = True

    if not check:
        time += 1
        continue

    rt[shortest] -= 1
    minm = rt[shortest]

    if minm == 0:
        minm = float('inf')

    if rt[shortest] == 0:
        complete += 1
        finish_time = time + 1

        wt[shortest] = finish_time - bt[shortest] - at[shortest]
        if wt[shortest] < 0:
            wt[shortest] = 0

    time += 1
    check = False

for i in range(n):
    tat[i] = bt[i] + wt[i]

print("\nProcess\tAT\tBT\tWT\tTAT")
for i in range(n):
    print(f"P{i+1}\t{at[i]}\t{bt[i]}\t{wt[i]}\t{tat[i]}")